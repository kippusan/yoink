# Copy this file to `.env` for local development.

# Core
# Root folder where final tagged downloads are written.
MUSIC_ROOT=./music
# SQLite DB path used by yoink-server.
DATABASE_URL=sqlite:./yoink.db?mode=rwc
# Preferred audio quality requested from download sources.
DEFAULT_QUALITY=LOSSLESS
# Max tracks processed in parallel per album job (1-16).
DOWNLOAD_MAX_PARALLEL_TRACKS=1
DOWNLOAD_LYRICS=false
LOG_FORMAT=pretty
LEPTOS_SITE_ROOT=target/site

# Providers
# Enable/disable providers independently.
TIDAL_ENABLED=true
MUSICBRAINZ_ENABLED=true
DEEZER_ENABLED=true
SOULSEEK_ENABLED=false

# Tidal API
# This is the base URL for your local hifi-api proxy/service.
# It is NOT the official Tidal web endpoint.
# In dev this usually runs on port 8000.
TIDAL_API_BASE_URL=http://127.0.0.1:8000
# Legacy alias still supported:
# HIFI_API_BASE_URL=http://127.0.0.1:8000

# slskd / SoulSeek
# slskd REST API base URL.
SLSKD_BASE_URL=http://127.0.0.1:5030
# slskd web auth credentials (leave blank if auth is disabled).
SLSKD_USERNAME=
SLSKD_PASSWORD=
# Local host path where slskd stores completed downloads.
# Yoink reads files from here before moving/tagging into MUSIC_ROOT.
SLSKD_DOWNLOADS_DIR=./development/slskd-data/downloads
